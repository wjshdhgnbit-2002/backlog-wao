# ────────────────────────────────────────────
#  Backlog Wao — Environment Variables
#  Copy this to .env.local for local dev
#  Add these in Netlify → Site Settings → Env Vars
# ────────────────────────────────────────────

# Your Steam Web API key — get it at:
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Your Steam 64-bit ID (17 digits).
# Find yours at: https://steamid.io
# If set, the app pre-loads your library automatically.
# Leave blank to show a manual Steam ID input form.
STEAM_ID=your_steam_id_here

# RAWG API key — free at:
# https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_api_key_here

# Anthropic API key — get it at:
# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
